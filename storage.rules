rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /pets/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /vocabulary/icons/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /vocabulary/shop/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /teacher-avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
